<?xml version="1.0" encoding="UTF-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" version="1.2">
  <file source-language="en" target-language="de-X-SIC" datatype="plaintext" original="EXT:core/Resources/Private/Language/locallang_mod_web_list.xlf">
    <header/>
    <body>
      <trans-unit id="mlang_labels_tablabel">
        <source>List of database records</source>
        <target>Liste aller Datenbank-Datensätze</target>
      </trans-unit>
      <trans-unit id="mlang_labels_tabdescr">
        <source>The Web&gt;List module provides low level access to records appearing on a page.</source>
        <target>Das Web&gt;Liste-Modul gibt dir lowkey Zugriff auf alle Datensätze einer Seite.</target>
      </trans-unit>
      <trans-unit id="mlang_tabs_tab">
        <source>List</source>
        <target>Liste</target>
      </trans-unit>
      <trans-unit id="clip_pasteAfter">
        <source>Paste after: Clipboard content is inserted after this record</source>
        <target>Danach einfügen: Clipboard-Inhalt wird nach diesem Datensatz eingefügt</target>
      </trans-unit>
      <trans-unit id="clip_pasteInto">
        <source>Paste into: Clipboard content is inserted on this page</source>
        <target>Reinfügen: Clipboard-Inhalt wird auf dieser Seite eingefügt</target>
      </trans-unit>
      <trans-unit id="clip_paste">
        <source>Paste in clipboard content</source>
        <target>Clipboard-Inhalt einfügen</target>
      </trans-unit>
      <trans-unit id="clip_markRecords">
        <source>Mark All/Mark none</source>
        <target>Alle markieren / Keinen markieren</target>
      </trans-unit>
      <trans-unit id="clip_selectMarked">
        <source>Transfer the selection of records to clipboard</source>
        <target>Auswahl ins Clipboard schieben</target>
      </trans-unit>
      <trans-unit id="clip_duplicates">
        <source>Mark duplicates</source>
        <target>Duplikate markieren</target>
      </trans-unit>
      <trans-unit id="clip_editMarked">
        <source>Edit marked</source>
        <target>Markierte flexen</target>
      </trans-unit>
      <trans-unit id="clip_deleteMarked">
        <source>Delete marked</source>
        <target>Markierte yeeten</target>
      </trans-unit>
      <trans-unit id="clip_deleteMarkedWarning">
        <source>Are you sure you want to delete all marked records from the table '%s'?</source>
        <target>Bist du sicher dass du alle markierten Datensätze aus der Tabelle '%s' yeeten willst?</target>
      </trans-unit>
      <trans-unit id="showInfo">
        <source>Info</source>
        <target>Info</target>
      </trans-unit>
      <trans-unit id="edit">
        <source>Edit record</source>
        <target>Datensatz flexen</target>
      </trans-unit>
      <trans-unit id="editPage">
        <source>Edit page properties</source>
        <target>Seiteneigenschaften flexen</target>
      </trans-unit>
      <trans-unit id="new">
        <source>New record</source>
        <target>Frischer Datensatz</target>
      </trans-unit>
      <trans-unit id="newRecordOfType">
        <source>New %s</source>
        <target>Neues %s</target>
      </trans-unit>
      <trans-unit id="newPage">
        <source>Create new page after this page</source>
        <target>Neue Seite nach dieser Seite droppen</target>
      </trans-unit>
      <trans-unit id="newRecord">
        <source>Create new record after this record</source>
        <target>Neuen Datensatz nach diesem hier droppen</target>
      </trans-unit>
      <trans-unit id="newRecordGeneral">
        <source>Create new record</source>
        <target>Neuen Datensatz droppen</target>
      </trans-unit>
      <trans-unit id="moveUp">
        <source>Move up in list</source>
        <target>In der Liste hoch schieben</target>
      </trans-unit>
      <trans-unit id="moveDown">
        <source>Move down in list</source>
        <target>In der Liste runter schieben</target>
      </trans-unit>
      <trans-unit id="move_record">
        <source>Re-position content element</source>
        <target>Content-Element umpositionieren</target>
      </trans-unit>
      <trans-unit id="move_page">
        <source>Move page</source>
        <target>Seite verschieben</target>
      </trans-unit>
      <trans-unit id="hide">
        <source>Hide record</source>
        <target>Datensatz ghosten</target>
      </trans-unit>
      <trans-unit id="unHide">
        <source>Un-hide record</source>
        <target>Datensatz entghostet</target>
      </trans-unit>
      <trans-unit id="hidePage">
        <source>Hide page</source>
        <target>Seite ghosten</target>
      </trans-unit>
      <trans-unit id="unHidePage">
        <source>Un-hide page</source>
        <target>Seite entghosten</target>
      </trans-unit>
      <trans-unit id="prevLevel">
        <source>Move this page to the position after the current parent page (Inwards)</source>
        <target>Seite hinter die aktuelle Elternseite schieben (rein)</target>
      </trans-unit>
      <trans-unit id="nextLevel">
        <source>Move this page to be a subpage of the page above (Outwards)</source>
        <target>Seite als Unterseite der Seite drüber schieben (raus)</target>
      </trans-unit>
      <trans-unit id="delete">
        <source>Delete</source>
        <target>Yeeten</target>
      </trans-unit>
      <trans-unit id="history">
        <source>History/Undo</source>
        <target>Zeitreise/Rückgängig</target>
      </trans-unit>
      <trans-unit id="displayVersions">
        <source>Display versions</source>
        <target>Versionen checken</target>
      </trans-unit>
      <trans-unit id="permissions">
        <source>Set permissions for page</source>
        <target>Rechte für die Seite setzen</target>
      </trans-unit>
      <trans-unit id="largeControl">
        <source>Extended view</source>
        <target>Extended View</target>
      </trans-unit>
      <trans-unit id="contractView">
        <source>List all tables</source>
        <target>Alle Tabellen anzeigen</target>
      </trans-unit>
      <trans-unit id="expandView">
        <source>List only this table</source>
        <target>Nur diese Tabelle anzeigen</target>
      </trans-unit>
      <trans-unit id="collapseExpandTable">
        <source>Collapse and expand records of table "%s"</source>
        <target>Datensätze der Tabelle "%s" ein- und ausklappen</target>
      </trans-unit>
      <trans-unit id="showClipBoard">
        <source>Show clipboard</source>
        <target>Clipboard anzeigen</target>
      </trans-unit>
      <trans-unit id="editShownColumns">
        <source>Edit all shown fields of the listed records</source>
        <target>Alle nicht geghosteten Felder der gelisteten Datensätze flexen</target>
      </trans-unit>
      <trans-unit id="editThisColumn">
        <source>Edit the '%s' field of the listed records</source>
        <target>Das '%s'-Feld der gelisteten Datensätze flexen</target>
      </trans-unit>
      <trans-unit id="deleteWarning">
        <source>Are you sure you want to delete the record '%s'?</source>
        <target>Bist du sicher dass du '%s' yeeten willst, Digga?</target>
      </trans-unit>
      <trans-unit id="localization">
        <source>Localization view</source>
        <target>Übersetzungs-Ansicht</target>
      </trans-unit>
      <trans-unit id="defaultLanguage">
        <source>Default</source>
        <target>Standard</target>
      </trans-unit>
      <trans-unit id="multipleLanguages">
        <source>All languages</source>
        <target>Alle Sprachen</target>
      </trans-unit>
      <trans-unit id="Localize">
        <source>Localize to</source>
        <target>Übersetzen nach</target>
      </trans-unit>
      <trans-unit id="viewRecords">
        <source>Viewing records of</source>
        <target>Datensätze anschauen von</target>
      </trans-unit>
      <trans-unit id="pageIndicator">
        <source>Page %1$s of %2$d</source>
        <target>Seite %1$s von %2$d</target>
      </trans-unit>
      <trans-unit id="rangeIndicator">
        <source>Records %1$d - %2$d</source>
        <target>Datensätze %1$d - %2$d</target>
      </trans-unit>
      <trans-unit id="missingTcaColumnsMessageTitle">
        <source>Missing TCA definition</source>
        <target>TCA-Definition fehlt, sheesh</target>
      </trans-unit>
      <trans-unit id="missingTcaColumnsMessage">
        <source>No fields for table "%s" have been found. $TCA['%s']['columns'] does not contain the necessary definitions.</source>
        <target>Keine Felder für Tabelle "%s" gefunden. $TCA['%s']['columns'] hat nicht die nötigen Definitionen, Brudi.</target>
      </trans-unit>
      <trans-unit id="noRecordsOnThisPage">
        <source>There are no records on this page.</source>
        <target>Auf dieser Seite ist nix, Digga.</target>
      </trans-unit>
      <trans-unit id="noRecordsOfTypeOnThisPage">
        <source>There are no records of type "%s" on this page.</source>
        <target>Keine Datensätze vom Typ "%s" auf dieser Seite.</target>
      </trans-unit>
      <trans-unit id="button.cancel">
        <source>Cancel</source>
        <target>Lass stecken</target>
      </trans-unit>
      <trans-unit id="button.close">
        <source>Close</source>
        <target>Tschüssikowski</target>
      </trans-unit>
      <trans-unit id="button.ok">
        <source>OK</source>
        <target>Slay!</target>
      </trans-unit>
      <trans-unit id="button.delete">
        <source>Delete</source>
        <target>Yeeten</target>
      </trans-unit>
    </body>
  </file>
