<?xml version="1.0" encoding="UTF-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" version="1.2">
  <file source-language="en" target-language="de-X-SIC" datatype="plaintext" original="EXT:redirects/Resources/Private/Language/Modules/qrcodes.xlf">
    <header/>
    <body>
      <trans-unit id="title">
        <source>QR Codes</source>
        <target>QR-Codes</target>
      </trans-unit>
      <trans-unit id="short_description">
        <source>QR Codes Administration</source>
        <target>QR-Code-Verwaltung</target>
      </trans-unit>
      <trans-unit id="description">
        <source>Generate and customize QR codes to provide quick, scannable access to your digital content.</source>
        <target>QR-Codes generieren und anpassen fuer schnellen Scan-Zugang zu deinem Content, sheesh.</target>
      </trans-unit>
      <trans-unit id="heading_text">
        <source>QR Code Management</source>
        <target>QR-Code-Management</target>
      </trans-unit>
      <trans-unit id="add_text">
        <source>Add QR Code</source>
        <target>QR-Code dazu packen, Bro</target>
      </trans-unit>
      <trans-unit id="not_found_with_filter.message">
        <source>No QR Code could be found with the current set of filters applied.</source>
        <target>Kein QR-Code mit den aktuellen Filtern gefunden.</target>
      </trans-unit>
      <trans-unit id="not_found.title">
        <source>No QR Codes found</source>
        <target>Nix am Start, keine QR-Codes</target>
      </trans-unit>
      <trans-unit id="not_found.message">
        <source>There are currently no QR Codes found in the database.</source>
        <target>Aktuell keine QR-Codes in der Datenbank. Voll leer hier.</target>
      </trans-unit>
      <trans-unit id="create">
        <source>Create new QR Code</source>
        <target>Neuen QR-Code droppen</target>
      </trans-unit>
      <trans-unit id="delete.title">
        <source>Delete QR Codes</source>
        <target>QR-Codes yeeten</target>
      </trans-unit>
      <trans-unit id="delete.message">
        <source>Delete all marked QR Codes permanently? You cannot undo this action.</source>
        <target>Alle markierten QR-Codes permanent yeeten? Das kannst du nicht rueckgaengig machen, Brudi!</target>
      </trans-unit>
      <trans-unit id="download">
        <source>Download</source>
        <target>Download</target>
      </trans-unit>
      <trans-unit id="show">
        <source>Show QR Code</source>
        <target>QR-Code zeig mal</target>
      </trans-unit>
    </body>
  </file>
</xliff>
